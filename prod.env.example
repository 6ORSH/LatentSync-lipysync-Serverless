# Copy to prod.env (gitignored) for LOCAL development only.
# In RunPod these are injected as env vars (see .runpod/hub.json) — do NOT ship .env files.

# Cloudflare R2 — credentials are account-wide
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# Production bucket
PROD_R2_BUCKET=latentsync-prod
