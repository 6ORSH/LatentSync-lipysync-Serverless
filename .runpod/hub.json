{
  "title": "Latentsync lipsync",
  "description": "Latentsync lipsync with request-level routing between staging and production Cloudflare R2 buckets",
  "type": "serverless",
  "category": "video",

  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 50,

    "env": [
      {
        "key": "R2_ACCOUNT_ID",
        "input": {
          "name": "Cloudflare R2 Account ID",
          "type": "string",
          "description": "Used to build the R2 endpoint https://<id>.r2.cloudflarestorage.com"
        }
      },
      {
        "key": "R2_ACCESS_KEY_ID",
        "input": {
          "name": "R2 Access Key ID",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "R2_SECRET_ACCESS_KEY",
        "input": {
          "name": "R2 Secret Access Key",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "STAG_R2_BUCKET",
        "input": {
          "name": "Staging R2 Bucket",
          "type": "string",
          "description": "R2 bucket for staging inputs/outputs"
        }
      },
      {
        "key": "PROD_R2_BUCKET",
        "input": {
          "name": "Production R2 Bucket",
          "type": "string",
          "description": "R2 bucket for production inputs/outputs"
        }
      }
    ]
  }
}
