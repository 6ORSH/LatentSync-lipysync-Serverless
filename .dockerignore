# Git
.git
.gitignore
.dockerignore

# Python caches
**/__pycache__
**/*.pyc
**/*.pyo
.venv
venv
env

# Local checkpoints (baked at build time instead)
checkpoints/

# Env files with secrets — injected at runtime by RunPod, never bake into the image
.env
.env.*
*.env

# Local media / artifacts
*.mp4
*.wav
response.json

# Editor / OS
.idea
.vscode
.DS_Store
Thumbs.db

# Docs (not needed at runtime)
*.md
LatentSync/docs
LatentSync/eval
